# GEMINI_API_KEY: Required for Gemini AI API calls. (Google AI Studio)
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GNEWS_API_KEY: GNews.io üzerinden ücretsiz günlük 100 çağrılık kota ile alınabilir
GNEWS_API_KEY=your_gnews_api_key_here

# TELEGRAM_BOT_TOKEN: Telegram'da @BotFather üzerinden yeni bot oluşturup alınabilir
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
